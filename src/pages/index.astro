---
import Layout from '../layouts/Layout.astro';

import AboutMe from '@components/home/about-me/index.astro';
import Experience from '@components/home/experience/index.astro';
import Education from '@components/home/experience/topics/education/index.astro';
import Employment from '@components/home/experience/topics/employment/index.astro';
import Training from '@components/home/experience/topics/training/index.astro';
import WhatIdo from '@components/home/what-do-i-do/index.astro';

import { calcLengthInYears } from '../lib/utils';

const dateFrom = new Date('2010-01-01T00:00:00+00:00');
const dateTo = new Date();

const metaData = {
    description: `I am a Product Manager with ${calcLengthInYears(
        dateFrom,
        dateTo
    )} of experience, primarily in internal platforms and B2B SaaS applications.`,
    additionalMetaTags: [
        {
            name: 'google-site-verification',
            content: 'F_gIghpXfLjo0LORq-3zJ1HjUIlKmy2iTb9lWQD_BfM'
        }
    ]
};
---

<Layout metaData={metaData}>
    <AboutMe />
    <Experience />
    <WhatIdo />
    <Employment />
    <Education />
    <Training />
</Layout>
