---
const socials = [
    {
        site: 'LinkedIn',
        uri: 'https://www.linkedin.com/in/matthewwittering/'
    },
    {
        site: 'Github',
        uri: 'https://github.com/mjakinowittering'
    }
];
---

<footer>
    <nav>
        <ol class="flex justify-start space-x-4">
            {
                socials.map((social) => (
                    <li class="flex h-12 items-center justify-center px-4 py-2 hover:rounded-lg hover:bg-gray-100">
                        <a
                            href={social.uri}
                            aria-label={`Profile page on ${social.site}`}
                            title={`Profile page on ${social.site}`}
                        >
                            {social.site}
                        </a>
                    </li>
                ))
            }
        </ol>
    </nav>
</footer>
