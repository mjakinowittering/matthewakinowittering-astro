---
import Button from '@components/block/Button.astro';
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
    project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { img, alt, title, description, tags, uri, sourceUri } = project.data;
---

<div
    class="border-border bg-bg grid overflow-hidden rounded-[14px] border md:grid-cols-2"
>
    {
        img ? (
            <Image
                src={img}
                alt={alt ?? title}
                class="h-full w-full object-cover"
            />
        ) : (
            <div class="text-muted flex min-h-[260px] items-center justify-center bg-[repeating-linear-gradient(135deg,var(--color-border)_0,var(--color-border)_2px,transparent_2px,transparent_14px)] p-5 text-center font-mono text-[11px] tracking-[0.06em] uppercase">
                app screenshot goes here · youdemo recorder ui
            </div>
        )
    }
    <div class="flex flex-col gap-[14px] p-8">
        <h3 class="text-2xl font-bold">{title}</h3>
        <p class="text-muted text-[15px] leading-[1.6]">{description}</p>
        <div class="flex flex-wrap gap-2">
            {
                tags.map((tag) => (
                    <span class="bg-accent-soft text-accent-strong rounded-full px-[10px] py-[5px] text-[10.5px] font-bold tracking-[0.04em] uppercase">
                        {tag}
                    </span>
                ))
            }
        </div>
        <div class="mt-1.5 flex flex-wrap gap-3">
            <Button href={uri} external>Try it live</Button>
            <Button href={sourceUri} variant="ghost" external>
                View source
            </Button>
        </div>
    </div>
</div>
