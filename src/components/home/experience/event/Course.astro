---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import { formatMonthYear } from '../../../../lib/utils';

interface Props {
    event: CollectionEntry<'events'>;
}

const { event } = Astro.props;

const { Content } = await render(event);
---

<details class="group border-border block border-b border-dashed py-2.5">
    <summary
        class="text-muted after:text-muted flex cursor-pointer list-none items-baseline gap-4 text-[13.5px] after:ml-2 after:flex-none after:font-bold after:content-['+'] group-open:after:content-['–'] [&::-webkit-details-marker]:hidden"
    >
        <span class="text-ink flex-1 font-semibold">{event.data.title}</span>
        <span class="flex-none text-right text-xs whitespace-nowrap">
            {formatMonthYear(event.data.dateFrom)}
        </span>
    </summary>
    <div
        class="prose text-muted prose-p:text-sm prose-p:leading-[1.6] prose-p:text-muted mt-2 max-w-[64ch]"
    >
        {Content ? <Content /> : <p>Content not found</p>}
    </div>
</details>
