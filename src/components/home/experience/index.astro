---
import { getEntry, render } from 'astro:content';

import BlockContent from '@components/block/content.astro';
import Block from '@components/block/index.astro';
import BlockTitle from '@components/block/title.astro';

const blurb = await getEntry('blurbs', 'experience');

if (!blurb) return Astro.redirect('/404');

const { Content } = await render(blurb);
---

<div class="flex-grow bg-[#f7f7f4]">
    <div class="container mx-auto max-w-6xl space-y-16 py-16 md:space-y-32">
        <Block>
            <div class="flex flex-col space-y-8">
                <BlockTitle>{blurb?.data.title}</BlockTitle>
                <BlockContent>
                    {Content ? <Content /> : <p>Content not found</p>}
                </BlockContent>
            </div>
        </Block>
    </div>
</div>
