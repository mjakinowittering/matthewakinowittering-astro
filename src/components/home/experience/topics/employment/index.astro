---
import Badge from '@components/block/Badge.astro';
import Section from '@components/block/Section.astro';
import SectionHead from '@components/block/SectionHead.astro';
import Organisation from '@components/home/experience/organisation/index.astro';
import { Building } from '@lucide/astro';
import { getCollection } from 'astro:content';

const employmentEvents = await getCollection('events', ({ data }) => {
    return data.type === 'employment';
});

const companies = (
    await getCollection('organisations', ({ data }) => {
        return data.type === 'employer';
    })
)
    .map((company) => {
        const companyEvents = employmentEvents.filter(
            (event) => event.data.organisationId.id === company.data.id
        );

        if (companyEvents.length === 0) {
            return null;
        }

        const dateFrom = companyEvents.reduce((earliest, event) => {
            return event.data.dateFrom < earliest
                ? event.data.dateFrom
                : earliest;
        }, companyEvents[0].data.dateFrom);

        return {
            ...company,
            data: { ...company.data, dateFrom }
        };
    })
    .filter((company) => company !== null)
    .sort(function (a, b) {
        return b.data.dateFrom.getTime() - a.data.dateFrom.getTime();
    });
---

<Section id="career" alt>
    <SectionHead
        title="Career"
        subtitle="Where I've worked and what I've built"
    >
        <Badge slot="badge" label="Employer">
            <Building size={26} stroke-width={1.5} />
        </Badge>
    </SectionHead>
    <div class="mt-9">
        {
            companies.map((company, index) => (
                <Organisation
                    organisation={company}
                    isLast={index === companies.length - 1}
                />
            ))
        }
    </div>
</Section>
