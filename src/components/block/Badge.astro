---
interface Props {
    label: string;
}

const { label } = Astro.props;
---

<div class="flex flex-none flex-col items-center gap-2">
    <div
        class="border-border bg-bg text-accent-strong flex h-15 w-15 items-center justify-center rounded-full border-[1.5px]"
    >
        <slot />
    </div>
    <span class="text-muted text-[10px] font-bold tracking-[0.1em] uppercase">
        {label}
    </span>
</div>
