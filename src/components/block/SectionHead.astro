---
interface Props {
    title: string;
    subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="flex items-start justify-between gap-6">
    <div>
        <h2
            class="text-accent-strong text-[32px] leading-[1.15] font-extrabold tracking-[-0.01em]"
        >
            {title}
        </h2>
        {
            subtitle && (
                <p class="text-ink text-[15px] leading-[1.65] font-semibold">
                    {subtitle}
                </p>
            )
        }
    </div>
    <slot name="badge" />
</div>
